{
    "TemplateName": "OtpVerificationTemplate",
    "TemplateContent": {
      "Subject": "Tu código de verificación es {{code}}",
      "Html": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <title>Código de verificación</title>\n</head>\n<body style=\"margin:0;padding:0;background-color:#f4f6f8;font-family:Arial,Helvetica,sans-serif;\">\n    <table align=\"center\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:600px;margin:40px auto;background:#ffffff;border-radius:8px;padding:40px;\">\n        <tr>\n            <td style=\"text-align:left;\">\n                <h2 style=\"margin-top:0;color:#333333;\">\n                    Hola {{name}},\n                </h2>\n                <p style=\"font-size:16px;color:#555555;\">\n                    Hemos recibido una solicitud para verificar tu identidad.\n                </p>\n                <p style=\"font-size:16px;color:#555555;\">\n                    Usa el siguiente código de verificación:\n                </p>\n                <div style=\"text-align:center;margin:30px 0;\">\n                    <span style=\"display:inline-block;font-size:28px;font-weight:bold;letter-spacing:6px;padding:15px 25px;background:#f0f2f5;border-radius:6px;color:#111111;\">\n                        {{code}}\n                    </span>\n                </div>\n                <p style=\"font-size:14px;color:#888888;\">\n                    Este código expirará en unos minutos.  \n                    Si no solicitaste este código, puedes ignorar este correo.\n                </p>\n                <hr style=\"border:none;border-top:1px solid #eeeeee;margin:30px 0;\" />\n                <p style=\"font-size:12px;color:#aaaaaa;\">\n                    © 2026 Tu Aplicación. Todos los derechos reservados.\n                </p>\n            </td>\n        </tr>\n    </table>\n</body>\n</html>",
      "Text": "Hola {{name}},\n\nTu código de verificación es {{code}}\n\nEste código expirará en {{ValidForMinutes}} minutos. Si no solicitaste este mensaje, puedes ignorarlo."
  }
}